RU_LOCAL_AVATAR_ENV=development
RU_LOCAL_AVATAR_PROFILE=/app/profiles/rtx5090.yaml
RU_LOCAL_AVATAR_PUBLIC_STATUS=0
RU_LOCAL_AVATAR_MAX_ACTIVE_VOICE_SESSIONS=1
RU_LOCAL_AVATAR_SESSION_TTL_SECONDS=900
LOCAL_BIND_ADDRESS=127.0.0.1
AGENT_BIND_HOST=0.0.0.0

LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_local_only_32chars

AGENT_BASE_IMAGE=vllm/vllm-openai:latest
VLLM_IMAGE=vllm/vllm-openai:latest
LIVEKIT_IMAGE=livekit/livekit-server:latest

WEB_HOST_PORT=46174
AGENT_HOST_PORT=46181
AGENT_INTERNAL_PORT=46183
VLLM_HOST_PORT=46111
LIVEKIT_HOST_PORT=46280
LIVEKIT_RTC_TCP_HOST_PORT=46281
LIVEKIT_RTC_UDP_HOST_PORT=46282
PROMETHEUS_HOST_PORT=46909
GRAFANA_HOST_PORT=46300

# Docker bridge gateway used by the agent API proxy when the agent itself runs
# with host networking for LiveKit/WebRTC.
WSL_BRIDGE_GATEWAY=172.23.0.1

QWEN_MODEL_PATH=/models/hf/Qwen__Qwen3-14B-FP8
QWEN_SERVED_MODEL_NAME=Qwen/Qwen3-14B-FP8
VLLM_WSL2_ENABLE_PIN_MEMORY=1
VLLM_USE_DEEP_GEMM=0
VLLM_KV_CACHE_DTYPE=fp8
VLLM_MAX_MODEL_LEN=1536
# Tight single-GPU budget: 0.49 is below the KV-cache floor for Qwen3-14B-FP8
# in this vLLM build; 0.50 is the lowest confirmed working value.
VLLM_GPU_MEMORY_UTILIZATION=0.50
